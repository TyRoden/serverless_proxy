# RunPod Serverless Proxy - Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_ENDPOINT_ID=your_endpoint_id
MODEL_NAME=your-openwebui-model-name
ENDPOINT_TYPE=ollama
TIMEOUT=300

# AI Queue Master Integration (optional)
# Route requests through AI Queue Master for priority queuing and history tracking
USE_AI_QUEUE=false
AI_QUEUE_URL=http://host.docker.internal:8102
AI_QUEUE_API_KEY=your_queue_api_key
AI_QUEUE_PRIORITY=NORMAL  # HIGH, NORMAL, or LOW
AI_QUEUE_SOURCE=runpod-proxy
